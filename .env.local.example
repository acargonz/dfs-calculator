# Copy this file to .env.local and fill in your keys:
#   cp .env.local.example .env.local
#
# Server-side keys (never exposed to the browser):
ODDS_API_KEY=your_odds_api_key_here                  # https://the-odds-api.com (free tier: 500 req/mo)
BALLDONTLIE_API_KEY=your_balldontlie_key_here        # https://balldontlie.io (position lookups only)
GEMINI_API_KEY=your_gemini_key_here                  # https://aistudio.google.com (free: 15 RPM, 1M tokens/day)
CLAUDE_API_KEY=your_claude_key_here                  # Optional — pay-per-use Anthropic API

# Client-safe keys (exposed to the browser — Supabase RLS enforces server-side):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Note: ESPN endpoints (injuries, rosters) and PBP Stats require no API keys.
