# Copy this file to .env.local and fill in your keys:
#   cp .env.local.example .env.local
#
# SECURITY NOTE:
#   Every variable in this file (except the two `NEXT_PUBLIC_*` ones at the
#   bottom) is SERVER-ONLY. Next.js inlines any variable prefixed with
#   `NEXT_PUBLIC_` into the browser bundle, where it becomes trivially
#   retrievable by anyone with DevTools. Do NOT add that prefix to any
#   paid API key — the moment you do, your key is public.
#
# =========================================================================
# 1. Third-party data providers (server-only)
# =========================================================================

# The Odds API — https://the-odds-api.com (free tier: 500 req/mo)
ODDS_API_KEY=your_odds_api_key_here

# balldontlie — https://balldontlie.io (position lookups only)
BALLDONTLIE_API_KEY=your_balldontlie_key_here

# Google Gemini — https://aistudio.google.com (free: 15 RPM, 1M tokens/day)
# PROTECT THIS with a GCP Cloud Billing budget (see SECURITY_DEPLOYMENT_CHECKLIST.md
# step 1 — "GCP Hard Billing Cap"). Without the cap, a single compromised key
# can bankrupt you in hours.
GEMINI_API_KEY=your_gemini_key_here

# Anthropic Claude — optional, pay-per-use
CLAUDE_API_KEY=your_claude_key_here

# OpenRouter — optional, aggregated LLM gateway
OPENROUTER_API_KEY=your_openrouter_key_here

# =========================================================================
# 2. Supabase (server-only after security migration)
# =========================================================================
#
# IMPORTANT: these used to be prefixed `NEXT_PUBLIC_*` and shipped to the
# browser. After migration 003 the anon key is no longer useful from the
# client (default-deny RLS), and all server code now uses the SERVICE ROLE
# key instead. Do not re-add the `NEXT_PUBLIC_` prefix — the service role
# key bypasses RLS and would be catastrophic if leaked.

# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Service-role key (Project Settings → API → service_role). Treat this like
# a root database password. Never commit. Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =========================================================================
# 3. Cron authentication (server-only)
# =========================================================================
#
# Vercel cron jobs automatically send this as `Authorization: Bearer <value>`
# when calling /api/snapshot-closing-lines and /api/resolve-picks.
#
# REQUIRED in production — routes fail-closed (503) if unset on Vercel.
# Generate a fresh value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_long_random_hex_string_here

# =========================================================================
# 4. Origin allowlist (optional but strongly recommended)
# =========================================================================
#
# Used by /api/analyze to reject cross-origin browser requests from
# attacker sites trying to drain your LLM quota. Set this to your primary
# production URL. Add additional comma-separated origins via ALLOWED_ORIGINS.
#
# Note: unlike other env vars in this file, NEXT_PUBLIC_SITE_URL *is*
# prefixed because the client-side code also reads it to build canonical
# URLs. It's not a secret — it's literally the URL you'd paste into a
# browser.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
ALLOWED_ORIGINS=

# =========================================================================
# 5. Postseason override (optional)
# =========================================================================
#
# Override the YYYY-06-04 default for the regular→playoffs/finals split.
# Update each year once the official Game-1 date is announced.
# NBA_FINALS_START_DATE=2026-06-04

# =========================================================================
# Note: ESPN endpoints (injuries, rosters) and PBP Stats require no API keys.
# =========================================================================
